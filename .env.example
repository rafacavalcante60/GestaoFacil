# Copie para .env (o .env esta no .gitignore — nunca commite o real).
# Local: docker compose up -d --build

MYSQL_ROOT_PASSWORD=troque-esta-senha
MYSQL_DATABASE=gestaofacilbanco

# minimo 32 caracteres. NUNCA reutilize a chave antiga que esta no historico do git.
JWT_KEY=gere-uma-chave-nova-com-openssl-rand-base64-48
ADMIN_PASSWORD=defina-uma-senha-forte

# base dos links de "esqueci minha senha" — em producao vira https://seu-dominio
FRONTEND_BASE_URL=http://localhost:8080
