# O Caddy termina o TLS: ele obtem e renova o certificado Let's Encrypt sozinho
# (basta o dominio apontar para o Elastic IP e as portas 80/443 abertas no SG) e
# repassa a requisicao em HTTP puro para o app na rede interna do compose.
{$DOMAIN} {
	encode gzip

	# o Caddy ja envia X-Forwarded-For e X-Forwarded-Proto por padrao. O app
	# depende deles: particiona o rate limiting por IP e, sem esses cabecalhos,
	# enxergaria so o IP do proprio Caddy e limitaria todos os usuarios juntos.
	reverse_proxy app:8080
}
