# Copie para .env NA VM (nunca commite o real) e rode:
#   docker compose -f docker-compose.prod.yml up -d --build

# Dominio que aponta para o IP publico da VM. O Caddy so consegue emitir o
# certificado depois que o DNS estiver propagado.
# Para a primeira validacao da Fase 2 da para usar o FQDN gratuito que a
# propria Azure fornece (ex: gestaofacil.northcentralus.cloudapp.azure.com) —
# o Let's Encrypt emite certificado para ele normalmente, e voce so compra o
# dominio proprio depois que a stack inteira estiver comprovadamente no ar.
DOMAIN=gestaofacil.northcentralus.cloudapp.azure.com

# MySQL roda em container na propria VM (nao ha banco gerenciado neste setup).
# Gere as duas senhas com: openssl rand -base64 32
DB_NAME=gestaofacilbanco
DB_USER=gestaofacil
DB_PASSWORD=
DB_ROOT_PASSWORD=

# gere com: openssl rand -base64 48
# NUNCA reutilize a chave antiga — ela esta no historico do git.
JWT_KEY=
ADMIN_PASSWORD=

# SMTP do "esqueci minha senha" (chave gerada no painel da Brevo).
# Opcional: sem estas variaveis o app sobe e so o fluxo de senha falha.
# NUNCA reutilize a chave antiga — ela esta no historico do git e foi revogada.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contato.gestaofacil@outlook.com
