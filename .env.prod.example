# Copie para .env NA EC2 (nunca commite o real) e rode:
#   docker compose -f docker-compose.prod.yml up -d --build

# dominio registrado, ja apontando (registro A) para o Elastic IP da EC2.
# O Caddy so consegue emitir o certificado depois que o DNS estiver propagado.
DOMAIN=seu-dominio.com

# endpoint do RDS (Public access = No, mesma VPC da EC2)
DB_HOST=gestaofacil.xxxxxxxx.us-east-1.rds.amazonaws.com
DB_NAME=gestaofacilbanco
DB_USER=admin
DB_PASSWORD=

# gere com: openssl rand -base64 48
# NUNCA reutilize a chave antiga — ela esta no historico do git.
JWT_KEY=
ADMIN_PASSWORD=
