# Copie para .env NA VM (nunca commite o real) e rode:
#   docker compose -f docker-compose.prod.yml up -d --build

# Dominio que aponta para o IP publico da VM. O Caddy so emite o certificado
# depois que o DNS resolver.
# Na primeira subida use o FQDN gratuito da propria Azure — o Let's Encrypt
# emite certificado para ele normalmente. O dominio proprio e o ultimo passo,
# ja com a stack comprovadamente no ar.
DOMAIN=gestaofacil.eastus.cloudapp.azure.com

# "Azure Database for MySQL - flexible server" (o equivalente ao RDS).
# Criado com acesso privado na mesma VNet da VM, sem exposicao publica.
DB_HOST=gestaofacil-db.mysql.database.azure.com
DB_NAME=gestaofacilbanco
DB_USER=gestaofacil
DB_PASSWORD=

# gere com: openssl rand -base64 48
# NUNCA reutilize a chave antiga — ela esta no historico do git.
JWT_KEY=
ADMIN_PASSWORD=

# SMTP do "esqueci minha senha" (chave gerada no painel da Brevo).
# Opcional: sem estas variaveis o app sobe e so o fluxo de senha falha.
# NUNCA reutilize a chave antiga — ela esta no historico do git e foi revogada.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contato.gestaofacil@outlook.com
